    {
      "name": "Group C - Cards",
      "description": "APIs for card lifecycle management: activation, PIN generation, block, and unblock with OTP. All calls require mTLS.",
      "item": [
        {
          "name": "POST Activate Card",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "pm.test('Card activation response has correct fields', () => {",
                  "  pm.expect(body).to.have.property('card_id');",
                  "  pm.expect(body).to.have.property('status');",
                  "  pm.expect(body).to.have.property('activated_at');",
                  "  pm.expect(body.status).to.eql('active');",
                  "});"
                ]
              }
            }
          ],
