        <di:waypoint x="2010" y="328" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_API_To_AIComm" bpmnElement="Flow_API_To_AIComm">
        <di:waypoint x="2140" y="328" />
        <di:waypoint x="2200" y="328" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_AIComm_To_End" bpmnElement="Flow_AIComm_To_End">
        <di:waypoint x="2330" y="328" />
        <di:waypoint x="2400" y="328" />
      </bpmndi:BPMNEdge>

      <!-- Error flows to End Failed -->
      <bpmndi:BPMNEdge id="Edge_Error_DataCollection" bpmnElement="Flow_Error_DataCollection">
        <di:waypoint x="188" y="364" />
        <di:waypoint x="188" y="560" />
        <di:waypoint x="2418" y="560" />
        <di:waypoint x="2418" y="486" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Timer_DataCollection" bpmnElement="Flow_Timer_DataCollection">
        <di:waypoint x="232" y="364" />
        <di:waypoint x="232" y="580" />
        <di:waypoint x="2418" y="580" />
        <di:waypoint x="2418" y="486" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Error_Monitor" bpmnElement="Flow_Error_Monitor">
        <di:waypoint x="378" y="364" />
        <di:waypoint x="378" y="540" />
        <di:waypoint x="2418" y="540" />
        <di:waypoint x="2418" y="486" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Timer_Monitor" bpmnElement="Flow_Timer_Monitor">
        <di:waypoint x="422" y="364" />
