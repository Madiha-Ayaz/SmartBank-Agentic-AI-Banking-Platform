        <di:waypoint x="2418" y="600" />
        <di:waypoint x="2418" y="486" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Error_Fraud_End" bpmnElement="Flow_Error_Fraud">
        <di:waypoint x="828" y="160" />
        <di:waypoint x="828" y="530" />
        <di:waypoint x="2418" y="530" />
        <di:waypoint x="2418" y="486" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Error_Bill_End" bpmnElement="Flow_Error_Bill">
        <di:waypoint x="828" y="270" />
        <di:waypoint x="828" y="620" />
        <di:waypoint x="2418" y="620" />
        <di:waypoint x="2418" y="486" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Error_Recovery_End" bpmnElement="Flow_Error_Recovery">
